kind: llman.sdd.delta
ops[1]{op,req_id,title,statement,from,to,name}:
  add_requirement,ar04,"module-map-domain-runtime-protocol","System MUST update the module map so that src/domain/ hosts pure domain vocabulary (data types and errors with zero crate-internal dependencies), src/runtime_protocol/ hosts the agent↔infra runtime protocol contracts (traits) and their signature types, and src/agent/ hosts orchestration mechanisms that were previously misplaced in core/.",null,null,null
op_scenarios[1]{req_id,id,given,when,then}:
  ar04,"domain-runtime-protocol-exist","the source tree is inspected after the change",src/domain and src/runtime_protocol directories exist,"no domain vocabulary remains under src/runtime_protocol and no trait contracts remain under src/domain"
