kind: llman.sdd.delta
ops[3]{op,req_id,title,statement,from,to,name}:
  add_requirement,r1,"tool-trait","System MUST define a Tool trait compatible with adk-core FunctionTool for all built-in tools.",null,null,null
  add_requirement,r2,"seven-tools","System MUST implement 7 built-in tools: read bash edit write grep find ls.",null,null,null
  add_requirement,r3,"patch-apply","System MUST apply AI-generated patches using fudiff fuzzy matching with patch crate exact fallback.",null,null,null
op_scenarios[3]{req_id,id,given,when,then}:
  r1,happy,"",Tool trait is defined,"it implements the adk-core FunctionTool interface"
  r2,happy,a tool registry with all 7 tools,each tool is invoked with valid args,each returns a successful ToolResult
  r3,happy,"an AI-generated unified diff with slight line offset",patch is applied via fudiff,fudiff successfully applies despite line offset
