kind: llman.sdd.delta
ops[1]{op,req_id,title,statement,from,to,name}:
  add_requirement,ce8,"server-subcommands","The CLI MUST provide subcommands under server: run (start the server process with optional --port), install (register as launchd/systemd service), and stop (signal running server).",null,null,null
op_scenarios[1]{req_id,id,given,when,then}:
  ce8,"server-run-starts","user runs xylitol server run --port 9090","the server process starts","the lock file is created at the configured path and the REST API responds on port 9090"
