kind: llman.sdd.delta
ops[4]{op,req_id,title,statement,from,to,name}:
  add_requirement,e1,"fuzzy-match","System MUST perform fuzzy matching on edit oldText: NFKC normalize smart quotes to ASCII dashes to hyphen trailing whitespace strip then match progressively looser.",null,null,null
  add_requirement,e2,"line-ending","System MUST detect file line ending (CRLF vs LF) before editing and restore original style after applying changes.",null,null,null
  add_requirement,e3,"span-match","System MUST support matching multi-line oldText spans across different line segments when exact match fails.",null,null,null
  add_requirement,e4,"diff-output","System MUST compute structured diff output for review purposes after edit operations using the similar crate.",null,null,null
op_scenarios[4]{req_id,id,given,when,then}:
  e1,fuzzy,"file has curly quotes trailing whitespace or dashes but oldText uses ASCII equivalents","edit is applied","fuzzy match succeeds and replacement is written"
  e2,line-ending,"file uses CRLF or LF line endings","edit is applied","output file preserves the original line ending style"
  e3,span,"oldText spans 5 lines but exact match fails on one middle line","edit is applied with span matching","match succeeds via sliding window"
  e4,diff,"edit applies a change","diff is computed","result contains before and after lines with change markers"
