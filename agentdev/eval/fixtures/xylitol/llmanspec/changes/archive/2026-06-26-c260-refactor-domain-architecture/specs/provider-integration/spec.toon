kind: llman.sdd.delta
ops[2]{op,req_id,title,statement,from,to,name}:
  add_requirement,pi2,"provider-in-infra","All LLM provider implementations (OpenAI, Anthropic, Fake, Mock) MUST live under infra/provider/ and implement core::ports::XyModel; agent/ MUST NOT contain a provider/ subdirectory; provider construction (the factory from ModelConfig to Arc<dyn XyModel>) MUST live in infra::provider::factory, not in agent/.",null,null,null
  add_requirement,pi3,"provider-port-injection","The model registry held by the agent MUST store providers as Arc<dyn XyModel>; selecting a provider MUST NOT require the agent to name a concrete provider struct.",null,null,null
op_scenarios[2]{req_id,id,given,when,then}:
  pi2,"provider-moved","src/agent/provider is checked for existence","the path is inspected","it does not exist and src/infra/provider/ does"
  pi3,"no-concrete-provider","the agent references a provider","the reference type is inspected","it is the XyModel trait object not OpenAIProvider"
