kind: llman.sdd.delta
ops[8]{op,req_id,title,statement,from,to,name}:
  modify_requirement,la2,"downward-dependency","infra/ modules MUST NOT import any crate::agent symbol; agent/ modules MUST NOT import any concrete infra/ type (only via core ports); interactive/ modules MUST NOT import crate::agent or crate::infra except in the in-process composition root. core/ MUST have zero crate:: internal dependencies.",null,null,null
  add_requirement,la4,"interactive-rename","The interactive surface directory MUST be named interactive/ (not interface/); interface is reserved for the Rust trait concept.",null,null,null
  add_requirement,la5,"protocol-module","System MUST provide a protocol/ module as the single source of truth for client-core interaction: command enum (client to core), event enum (core to client), response envelope, and error codes.",null,null,null
  add_requirement,la6,"server-module","System MUST provide a server/ module that hosts agent + infra runtimes and exposes protocol/ over REST (/api/v1) and WebSocket; the server MUST enforce a single-instance lock.",null,null,null
  add_requirement,la7,"runtime-residence","All runtimes (provider, tool, session storage, exec-env) MUST live under infra/; agent/ MUST hold them only as Arc<dyn Port> injected at the composition root.",null,null,null
  add_requirement,la8,"agent-independence","The Agent facade constructor MUST NOT require a Session, MUST NOT hold a session_id, and MUST NOT depend on Session persistence lifecycle; session_id is a SessionStore query key bound in the interactive layer.",null,null,null
  add_requirement,la9,"arch-guard-expanded","System MUST enforce via a guard test (tests/architecture.rs) all of: no infra file imports crate::agent, no agent file imports a concrete infra/ type, no interactive file imports crate::agent or crate::infra except the in-process driver composition root.",null,null,null
  add_requirement,la10,"note-convention","Deliberate simplifications MUST be marked with a tool-agnostic comment of the form '// NOTE: <what>. ceiling: <when it breaks>. upgrade: <trigger>.' so they can be grepped and reaped.",null,null,null
op_scenarios[9]{req_id,id,given,when,then}:
  la2,"agent-no-infra-concrete","an agent/ source file is compiled","it references crate::infra::provider::OpenAIProvider or crate::infra::tools::BashTool","the build or guard rejects it"
  la2,"interactive-isolation","an interactive/ source file is compiled","it references crate::agent:: or crate::infra::","the build or guard rejects it unless it is the in-process driver root"
  la4,"dir-named-interactive","the source tree is inspected","src/interface no longer exists and src/interactive exists","the rename is complete"
  la5,"protocol-commands","a client sends a command to the core","the command is serialized","it deserializes into the protocol::Command enum defined in protocol/"
  la6,"single-instance","a second server process starts against the same lock path","it calls acquire_lock","it receives ServerLockedError"
  la7,"runtime-in-infra","a new LLM provider is added","the provider file is placed","it lives under infra/provider/ and implements core::ports::XyModel"
  la8,"facade-no-session","the Agent facade is constructed","only port trait objects are passed","construction succeeds without a Session instance or session_id"
  la9,"guard-catches-agent-leak","a new agent/ file adds use crate::infra::tools::BashTool","the architecture guard runs","the guard fails and reports the offending file path"
  la10,"note-greppable","a deliberate simplification is made in code","the author marks it","the line contains '// NOTE: ... ceiling: ... upgrade: ...' and is grep-findable"
