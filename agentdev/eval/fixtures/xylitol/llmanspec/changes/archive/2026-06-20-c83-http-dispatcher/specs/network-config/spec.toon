kind: llman.sdd.delta
ops[5]{op,req_id,title,statement,from,to,name}:
  add_requirement,nc1,proxy-config,"System MUST apply HTTP_PROXY and HTTPS_PROXY environment variables from the httpProxy setting.",null,null,null
  add_requirement,nc2,idle-timeout,"System MUST configure reqwest Client with configurable connect_timeout read_timeout and pool_idle_timeout.",null,null,null
  add_requirement,nc3,timeout-parser,"System MUST provide parse_http_idle_timeout_ms that accepts string 30 sec or numeric milliseconds.",null,null,null
  add_requirement,nc4,timeout-choices,"System MUST provide HTTP_IDLE_TIMEOUT_CHOICES constant with presets 30s 1min 2min 5min disabled.",null,null,null
  add_requirement,nc5,settings-stubs,"System SHALL add httpProxy httpIdleTimeoutMs websocketConnectTimeoutMs fields to Settings.",null,null,null
op_scenarios[6]{req_id,id,given,when,then}:
  nc1,proxy,'httpProxy is set to "http://proxy.example:8080"',apply_http_proxy_settings is called,"HTTP_PROXY and HTTPS_PROXY env vars are set"
  nc2,timeout,httpIdleTimeoutMs is 120000,configure_http_client is called,client has 120s read timeout
  nc3,parse-string,'value is "5 min"',parse is called,300000 is returned
  nc3,parse-numeric,value is 30000,parse is called,30000 is returned
  nc4,presets,"the timeout choices are accessed",HTTP_IDLE_TIMEOUT_CHOICES is read,"all 5 presets are present"
  nc5,stub-settings,"httpProxy and httpIdleTimeoutMs are set in settings",Settings is serialized to JSON,"both fields appear in camelCase"
