kind: llman.sdd.delta
ops[3]{op,req_id,title,statement,from,to,name}:
  modify_requirement,la9,"arch-guard-expanded","The architecture guard MUST enforce via a guard test (src/tests.rs::arch_guard) all of: no infra file imports crate::agent, no agent file imports ANY concrete crate::infra type via a full scan of crate::infra:: in production code (not limited to infra::provider::{openai,anthropic,fake,mock}), and no interactive file imports crate::agent or crate::infra except the in-process driver composition root; the scan scope MUST reconcile with la2 (agent imports no concrete infra type).",null,null,null
  add_requirement,la12,"arch-guard-allowlist","System MUST maintain a documented allowlist of pre-existing agent to infra import violations inside arch_guard; each allowlist entry MUST cite a follow-up change id that will remove it, and any NEW agent to infra production import not present in the allowlist MUST fail the guard.",null,null,null
  add_requirement,la13,"agent-thin-no-presentation","agent/ MUST NOT host pure presentation or user-guidance logic such as static help text or message formatting; such logic MUST live under interactive/ (the client surface), and agent/ MUST contain only the orchestration loop, hook points, and orchestration state.",null,null,null
op_scenarios[4]{req_id,id,given,when,then}:
  la9,"guard-catches-tools-leak","a new agent/ file adds use crate::infra::tools::BashTool or crate::infra::tools::accumulator in production code","the architecture guard runs","the guard fails and reports the offending file path even though it is not one of openai/anthropic/fake/mock"
  la9,"guard-catches-provider-factory","a new agent/ file calls crate::infra::provider::factory::build_provider in production code","the architecture guard runs","the guard fails because the scan is no longer limited to the four named provider impls"
  la12,"allowlist-blocks-new-violations","an agent file adds a NEW crate::infra import not listed in the allowlist","the guard runs","the build fails and the message names the file and says it is not in the allowlist"
  la13,"auth-guidance-not-in-agent","the source tree is inspected for user-guidance message formatting functions","src/agent/ is scanned","no pure presentation or static help-text module (such as the former agent::auth guidance) remains under agent/"
