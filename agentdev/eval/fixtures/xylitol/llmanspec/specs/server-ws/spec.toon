kind: llman.sdd.spec
name: "server-ws"
purpose: "TBD - created by archiving change c270-add-server-process. Update purpose after archive."
valid_scope[2]: src/,tests/
requirements[7]{req_id,title,statement}:
  w1,"ws-frame-protocol","Server → Client frames MUST be ServerFrame enum with ServerHello {version}, Ack {seq, request_id}, Event {session_id, seq, event}, and ResyncRequired {session_id} variants."
  w2,"ws-client-frames","Client → Server frames MUST be ClientFrame enum with Subscribe {session_id, last_seq}, ApproveTool {call_id, approved}, AnswerQuestion {call_id, answer}, and Ping variants."
  w3,"ws-handshake","On WS connect the server MUST wait for Subscribe, then respond with ServerHello + Ack; the server MUST mount a WebSocket upgrade handler under /api/v1/session/{id}/ws that carries this handshake."
  w4,"monotonic-seq",Each session MUST maintain a monotonic u64 sequence number that increments with every appended event; seq MUST be monotonically increasing per session.
  w5,"journal-ring","The server MUST maintain a ring-buffer journal of the most recent N events per session (default 10000); when the journal wraps past a client's last_seq, the server MUST emit ResyncRequired to that client."
  w6,"resync-flow","On receiving ResyncRequired, the client MUST resubscribe with an updated last_seq (e.g. 0 for full replay) to resume the event stream."
  w7,"ws-event-push","After the handshake, the server MUST push Event frames for every new event emitted by the agent, tagged with the session's monotonic seq; Event frames MUST be sent as JSON over the WS connection."
scenarios[7]{req_id,id,given,when,then}:
  w1,"frame-serialize","a ServerFrame::ServerHello is constructed",it is serialized to JSON,the JSON contains version field
  w2,"subscribe-frame",a client wants to subscribe to session s0 with last_seq 5,"a ClientFrame::Subscribe is created",it has session_id=s0 and last_seq=5
  w3,"ws-upgrade-mounted",a client connects to /api/v1/session/x/ws,the server accepts the upgrade,the client receives ServerHello then can send Subscribe
  w4,"seq-monotonic",3 events are appended to a session,the events are read back,"their seq values are 1,2,3 (strictly increasing)"
  w5,"resync-on-wrap",10001 events are appended to a session (journal capacity=10000),a client with last_seq=0 subscribes,the server sends ResyncRequired because events 0..1 are gone
  w6,"resync-recover",a client receives ResyncRequired,the client resubscribes with last_seq=0,the server replays all available events from the journal
  w7,"ws-events-pushed",a client subscribes and a prompt runs,the agent emits TextDelta events,the client receives Event frames on the WS connection
