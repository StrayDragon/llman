kind: llman.sdd.spec
name: "interactive-protocol"
purpose: "TBD - created by archiving change c260-refactor-domain-architecture. Update purpose after archive."
valid_scope[2]: src/,tests/
requirements[7]{req_id,title,statement}:
  ip1,"command-enum","protocol MUST define a Command enum covering at minimum Run Cancel SwitchModel SetThinking ListCommands ApproveTool AnswerQuestion SwitchSession GetMessages ExportHtml ExportJsonl and ImportJsonl; every client-to-core message MUST deserialize into this enum."
  ip2,"event-enum","protocol/ MUST define an Event enum covering at minimum TurnStart, Delta, ToolCall, ApprovalRequired, QuestionRequired, TurnEnd, and Usage; every core-to-client message MUST deserialize into this enum."
  ip3,"envelope-and-errors","protocol/ MUST define a uniform REST response envelope {code, msg, data, request_id} and a typed error-code set; envelope types live in protocol/ and MUST be transport-agnostic (no HTTP or WS types inside)."
  ip4,"rpc-becomes-transport","The existing interactive/rpc.rs MUST be reduced to a stdio transport that parses stdin into protocol::Command and serializes protocol::Event to stdout; its command/event types MUST move to protocol/ and MUST NOT be redefined locally."
  ip6,"subscribe-command","protocol/ MUST define Command::Subscribe {session_id, last_seq} for WS subscription and Event::Subscribed {session_id, seq} as the acknowledgment."
  ip7,"event-variants-complete","protocol::Event MUST cover all AgentEvent variants: TurnStart, TurnEnd, MessageStart, MessageEnd, MessageUpdate, ToolExecutionUpdate, and CompactionEnd in addition to the existing variants."
  ip8,"session-commands-dispatch","The RPC dispatch MUST implement SwitchSession by validating the target session exists via SessionStore and switching context; GetMessages by returning loaded SessionEntry records; ExportJsonl and ImportJsonl by delegating to AgentSession; stub or string-only implementations MUST NOT be shipped."
scenarios[8]{req_id,id,given,when,then}:
  ip1,"jsonl-commands-in-enum",the Command enum is inspected,ExportJsonl and ImportJsonl variants are checked,both variants are present and deserialize from client messages
  ip2,"approval-event",the agent needs a tool approved,an ApprovalRequired event is emitted,it carries a call_id and tool summary
  ip3,"envelope-serializes",an Envelope with code Ok and data is constructed,it is serialized to JSON,"the JSON has code, msg, data, and request_id fields"
  ip4,"rpc-thin",interactive/rpc.rs is inspected,its content is read,it contains only stdio framing and delegates to protocol types
  ip6,"subscribe-command-serializes","a Command::Subscribe {session_id: s0, last_seq: 5} is serialized to JSON",it is deserialized back,it matches original session_id and last_seq
  ip7,"event-roundtrip",all 7 new event variants are serialized to JSON,they are deserialized back,all fields match the original values
  ip8,"switch-validates-target","a client sends SwitchSession for a non-existent session id",the RPC dispatch handles it,an error is returned and the active session is NOT changed
  ip8,"get-messages-returns-entries",an active session with persisted entries exists,a GetMessages command is dispatched,the loaded SessionEntry records are returned (not a stub error)
