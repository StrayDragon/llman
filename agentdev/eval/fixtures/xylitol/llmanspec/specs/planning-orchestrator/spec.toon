kind: llman.sdd.spec
name: "planning-orchestrator"
purpose: "TBD - created by archiving change c55-add-planning-execution. Update purpose after archive."
valid_scope[2]: src/,tests/
requirements[2]{req_id,title,statement}:
  r1,"planner-executor-split",System MUST separate planning and execution into distinct roles with configurable model bindings.
  r2,"fallback-switch",System MUST support fallback model switching (OpenAI ↔ Anthropic) when primary model fails or loops.
scenarios[2]{req_id,id,given,when,then}:
  r1,happy,"planning model is claude-opus execution model is gpt-4o-mini",complex task is submitted,"planner decomposes task then executor runs each step with gpt-4o-mini"
  r2,happy,execution model enters repeat loop,"fallback specifies claude-opus","system switches to claude-opus automatically"
