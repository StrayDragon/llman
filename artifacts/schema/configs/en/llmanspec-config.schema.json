{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SddConfig",
  "description": "SDD project configuration for llmanspec.",
  "type": "object",
  "properties": {
    "schema": {
      "description": "Schema identifier. Must be \"spec-driven\".",
      "type": "string"
    },
    "locale": {
      "description": "Locale used for SDD templates and skills.",
      "type": "string",
      "default": "en"
    },
    "context": {
      "description": "Project context (tech stack, conventions, constraints). Replaces project.md.",
      "type": [
        "string",
        "null"
      ]
    },
    "rules": {
      "description": "Per-artifact rules. Map of artifact_id -> string[].",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "schema"
  ]
}
