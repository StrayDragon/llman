kind: llman.sdd.spec
name: "codex-account-management"
purpose: 规范 `llman x codex` 账户管理：编辑器命令参数支持与账户配置行为。
valid_scope[1]: "llmanspec/specs/codex-account-management"
requirements[2]{req_id,title,statement}:
  r1,"编辑器参数支持与 provider 配置 upsert","对应 spec: codex-account-management — 编辑器命令 MUST 支持 $VISUAL/$EDITOR 含参数； 切换组时 MUST 将 provider 配置 upsert 到 ~/.codex/config.toml 并设置顶层 model_provider，"
  r2,"环境变量安全、交互导入与命令透传","对应 spec: codex-account-management — env 注入 MUST 拒绝危险键（LD_PRELOAD/LD_LIBRARY_PATH/"
scenarios[0]:
