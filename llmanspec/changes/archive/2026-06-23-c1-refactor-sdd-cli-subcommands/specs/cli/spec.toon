kind: llman.sdd.delta
ops[6]{op,req_id,title,statement,from,to,name}:
  add_requirement,r2,Status Command,"System MUST provide a `status` subcommand that displays project overview including active changes count, pending validations, and specs count.",null,null,null
  add_requirement,r3,Unified Authoring Commands,"System MUST use consistent naming for spec and delta authoring commands (`add-req`, `remove-req`, `rename-req`).",null,null,null
  add_requirement,r4,Project Subgroup,"System MUST group non-core commands (`import`, `migrate`, `upgrade-guide`) under `sdd project` subgroup.",null,null,null
  add_requirement,r5,Alias Backward Compatibility,"System MUST provide deprecated aliases for renamed commands to maintain backward compatibility during migration period.",null,null,null
  add_requirement,r6,Archive Command Consistency,"System MUST remove legacy positional argument pattern from `archive` command and require explicit subcommand.",null,null,null
  add_requirement,r7,Simplified Show Options,"System MUST provide combined output options for `show` command to reduce option count.",null,null,null
op_scenarios[8]{req_id,id,given,when,then}:
  r2,status_json,"project has 2 active changes and 5 specs","user runs `llman sdd status --json`","system outputs JSON with active_changes=2 specs=5"
  r3,add_req_alias,"","user runs `llman sdd spec add-req`","system executes the add requirement command"
  r3,add_req_old_alias,"","user runs `llman sdd spec add-requirement`","system executes the add requirement command via alias"
  r4,project_import,"","user runs `llman sdd project import`","system executes the import command"
  r4,project_migrate,"","user runs `llman sdd project migrate`","system executes the migrate command"
  r5,deprecated_alias_works,"","user runs `llman sdd import`","system shows deprecation warning and executes import"
  r6,archive_requires_subcommand,"","user runs `llman sdd archive c1`","system returns error requiring `archive run c1`"
  r7,combined_output_option,"","user runs `llman sdd show c1 --output json,deltas`","system outputs JSON with deltas only"
