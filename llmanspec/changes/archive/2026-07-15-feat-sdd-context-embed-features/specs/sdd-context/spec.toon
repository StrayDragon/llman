kind: llman.sdd.delta
ops[1]{op,req_id,title,statement,from,to,name}:
  add_requirement,r3,Feature Embedding in Index,"`index_rebuild` MUST parse `*.feature` files in each spec directory using the Gherkin language derived from `config.yaml` locale and bdd settings. Parsed feature scenarios MUST be merged into the spec's scenarios (deduplicated by id, toon source wins on collision) with `req_id` set to empty (spec-level). The retrieval tool `get_document_structure` MUST list spec-level scenario ids in a top-level `scenarios` array. The retrieval tool `get_spec_content` MUST return an extra entry with `req_id` empty containing all spec-level scenarios' given/when/then. Specs without `.feature` files MUST produce unchanged index and retrieval output. A malformed `.feature` file MUST be skipped with a warning rather than aborting the rebuild.",null,null,null
op_scenarios[3]{req_id,id,given,when,then,feature}:
  r3,rebuild-embeds-feature-scenarios,"某 spec 目录同时含 spec.toon（含 1 个 feature:true 场景）与 1 个 .feature 文件（含 2 个场景）","执行 sdd index rebuild","tree.json 中该 spec 的 scenarios 含 3 个场景（toon 与 feature 合并去重）\nfeature 来源场景的 req_id 为空",true
  r3,get-spec-content-returns-spec-level-scenarios,"tree.json 中某 spec 含 req_id 为空的 spec 级别场景","调用 get_spec_content(spec_id, req_ids)","返回结果含一个 req_id 为空的额外条目\n该条目含全部 spec 级别场景的 given/when/then 全文",true
  r3,non-bdd-spec-unchanged,"某 spec 目录无 .feature 文件","执行 sdd index rebuild 后调用检索工具","scenarios 仅来自 spec.toon\n检索输出与无 feature 嵌入前完全一致",true
