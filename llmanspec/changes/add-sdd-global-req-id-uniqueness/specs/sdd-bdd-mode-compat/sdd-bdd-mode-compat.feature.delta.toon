kind: llman.sdd.feature_delta
target: global-req-id.feature
ops[2]{op,id,req_id,given,when,then}:
  add,global-req-collision-strict,r86,"已初始化含跨 spec 重复 req_id 的 sdd 项目且 bdd 配置为 \"on\"","在非交互终端运行 llman sdd validate --all --strict --no-check","退出码非零且 stderr 包含 Global duplicate req_id"
  add,global-req-collision-default,r86,"已初始化含跨 spec 重复 req_id 的 sdd 项目且 bdd 配置为 \"on\"","在非交互终端运行 llman sdd validate --specs --no-check","退出码非零且 stderr 包含 next-req-id"
